{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--browser",
        "chromium"
      ],
      "enabled": true
    },
    "railway": {
      "type": "local",
      "command": [
        "railway",
        "mcp"
      ],
      "enabled": true
    },
    "supabase": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest"
      ],
      "enabled": true
    }
  },
  "permission": {
    "doom_loop": "allow",
    "external_directory": {
      "*": "allow"
    }
  },
  "instructions": [
    "SKILL.md"
  ],
  "agent": {
    "factory": {
      "mode": "primary",
      "description": "Software factory stage agent",
      "steps": 200
    }
  }
}